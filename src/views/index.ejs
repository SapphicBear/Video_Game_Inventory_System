<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head.ejs"); %>
</head>
<body>
    <div class="wrapper">
    <header>
        <%- include("./partials/header.ejs"); %>
    </header>
        <main>
            <ul>
                <% games.map((game, i) => { %>
                    <li> 
                        <div class="gameContainer">
                            <h2>Game <%= i + 1 %></h2>
                            <p>Title: <%= game.game_name %></p>
                            <p>Game Studio: <%= game.studio_name %></p>
                            <p>Genre: <%= game.genre %></p>
                            <p>Release Year: <%= game.release_year %></p>
                            <p>On: <%= game.console %></p>
                            <p>Price: <%= game.price %></p>
                            <p>In stock: <%= game.in_stock %></p>
                        </div>
                    </li>
                <% }); %>
            </ul>
        </main>
        <aside class="sidebar">
            <%- include("./partials/sidebar.ejs", { genres: genres, consoles: consoles }) %>
        </aside>
    <footer>
        <%- include("./partials/footer.ejs", { links: links }); %>
    </footer>
    </div>
</body>
</html>