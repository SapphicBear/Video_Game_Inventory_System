<form action="/genres" method="GET">
    <div class="form-row">
        <label for="genre-select">Filter by Genre: </label>
        <select name="genres" id="genre-select">
            <option value="" disabled hidden selected>--Please choose an option--</option>
            <% genres.map((genre) => { %>
                <option value="<%= genre.genre %>"><%= genre.genre %></option>
            <% }); %>
        </select>
    </div>
        <span class="submit-area">
            <span><input type="checkbox" id="inStock-genres" name="inStock" value="In Stock">
            <label for="inStock-genres">Only show In Stock</label>
            </span>
            <button type="submit">Search</button>
        </span>
    
</form>
<form action="/consoles" method="GET">
    <div class="form-row">
        <label for="consoles-select">Filter by Consoles: </label>
        <select name="consoles" id="consoles-select">
            <option value="" disabled hidden selected>--Please choose an option--</option>
            <% consoles.map((console) => { %>
                <option value="<%= console.name %>"><%= console.name.replace("_", " "); %></option>
            <% }); %>
        </select>
    </div>
    <span class="submit-area">
        <span>
        <input type="checkbox" id="inStock-consoles" name="inStock" value="In Stock">
        <label for="inStock-consoles">Only show In Stock</label>
        </span>
        <button type="submit">Search</button>
        
    </span>
</form>
<form action="/studios" method="GET">
